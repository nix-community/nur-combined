From cd0f83db603f1e6036ec781ccdba2ed8d16213f4 Mon Sep 17 00:00:00 2001
From: Rhys-T <108157737+Rhys-T@users.noreply.github.com>
Date: Sun, 17 May 2026 16:06:25 -0400
Subject: [PATCH] feat: support running programs installed via Nix package
 manager

Adds read-only access to /nix/store, where the packages themselves are
kept. Everything in here is world-readable, and it's the closest thing
to e.g. /opt/homebrew or something.

Also adds read-only access to various symlinks needed to find the user's
current Nix profile. (The profile itself is in /nix/store, and consists
of symlinks to the various files of the user's installed packages,
combined into a single directory tree.)
---
 profiles/10-system-runtime.sb | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/profiles/10-system-runtime.sb b/profiles/10-system-runtime.sb
index b22703d..552b93c 100644
--- a/profiles/10-system-runtime.sb
+++ b/profiles/10-system-runtime.sb
@@ -12,6 +12,8 @@
     (subpath "/bin")                                                  ;; POSIX userland binaries used by shell/task orchestration.
     (subpath "/sbin")                                                 ;; System utilities some build/test flows invoke.
     (subpath "/opt")                                                  ;; Homebrew and other package-manager install roots.
+    (subpath "/nix/store")                                            ;; Nix package manager store / install root.
+    (subpath "/nix/var/nix/profiles")                                 ;; Nix package manager profile symlinks.
     (subpath "/System/Library")                                       ;; macOS runtime frameworks/resources; excludes broader /System/Volumes data paths.
     (subpath "/System/Volumes/Preboot")                               ;; Some dyld/framework lookups resolve through Preboot symlinks on modern macOS.
     (subpath "/Library/Apple")                                        ;; Apple private frameworks touched by Node/Bun/JVM/native toolchains.
@@ -56,6 +58,7 @@
 (allow file-read-metadata
     (literal "/home")                                                 ;; Probed during path resolution by some runtimes.
     (literal "/private/etc")                                          ;; Directory traversal for /etc path resolution.
+    (literal "/nix")                                                  ;; Directory traversal for /nix/store path resolution.
     (subpath "/dev")                                                  ;; Metadata (stat) on /dev entries; readdir() on /dev triggers this for every node.
     (home-literal "/.config")                                         ;; XDG config root traversal needed by many tools (mise, gh, git, etc.).
     (home-literal "/.cache")                                          ;; XDG cache root traversal needed by tools probing cache locations.
@@ -73,6 +76,10 @@
     (home-literal "/.config")                                         ;; XDG config root directory listing for tool discovery.
     (home-literal "/.cache")                                          ;; XDG cache root directory listing for tool discovery.
     (home-literal "/.local/bin")                                      ;; PATH probing may readdir ~/.local/bin before spawning user-installed helpers.
+    (home-literal "/.local/state/nix/profile")                        ;; Current profile symlink for Nix package manager.
+    (home-literal "/.nix-profile")                                    ;; Current profile symlink for Nix package manager (old non-XDG version).
+    (home-prefix "/.local/state/nix/profiles")                        ;; Directory of profile symlinks for Nix package manager since 2.14
+                                                                      ;; (previously /nix/var/nix/profiles/per-user/<username>).
 )
 
 ;; We intentionally do NOT block broad process primitives by default: agent workflows frequently chain many subprocesses.
