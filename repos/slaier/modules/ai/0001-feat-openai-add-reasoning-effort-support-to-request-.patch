From 9f122cd2fdfbe4a46663adceb68b1863df048f9e Mon Sep 17 00:00:00 2001
From: slaier <slaier@users.noreply.github.com>
Date: Sun, 21 Jun 2026 01:06:05 +0800
Subject: [PATCH] feat(openai): add reasoning effort support to request
 transformer

Implement transformRequestIn to map reasoning effort and clean up
unsupported fields before sending requests to OpenAI.
---
 packages/core/src/transformer/openai.transformer.ts | 12 ++++++++++++
 1 file changed, 12 insertions(+)

diff --git a/packages/core/src/transformer/openai.transformer.ts b/packages/core/src/transformer/openai.transformer.ts
index 106895b..6821a52 100644
--- a/packages/core/src/transformer/openai.transformer.ts
+++ b/packages/core/src/transformer/openai.transformer.ts
@@ -6,6 +6,18 @@ export class OpenAITransformer implements Transformer {
   endPoint = "/v1/chat/completions";
   logger?: any;
 
+  async transformRequestIn(
+    request: UnifiedChatRequest
+  ): Promise<UnifiedChatRequest> {
+    if (request.reasoning?.effort && request.reasoning.effort !== "none") {
+      (request as any).reasoning_effort = request.reasoning.effort;
+    }
+    delete request.reasoning;
+    delete (request as any).thinking;
+    delete (request as any).enable_thinking;
+    return request;
+  }
+
   /**
    * 将外部OpenAI格式的请求转换为内部统一格式
    *
-- 
