+def _fs_escape(path_str: str) -> str:
+    """Escape an absolute filesystem path for use as a directory name.
+
+    ``-`` is escaped to ``--`` and ``/`` is replaced with ``-``.  The root
+    directory ``/`` therefore maps to ``-``:
+
+    * ``/home/colin/src``  -> ``home-colin-src``
+    * ``/home-colin/src``  -> ``home--colin-src``
+    * ``/``                -> ``-``
+    """
+    if path_str == "/":
+        return "-"
+    # Drop the leading /.
+    assert path_str.startswith("/"), path_str
+    body = path_str[1:]
+    return body.replace("-", "--").replace("/", "-")
+
+
+def _default_store_dir(watched_dir: Path) -> Path:
+    """Derive a human-friendly store directory under ``~/.cache/coderag``.
+
+    Uses the git common-dir when available so worktrees of the same repo share
+    an index.  Falls back to the absolute ``watched_dir`` path for non-git
+    directories.
+    """
+    abs_watched = watched_dir.expanduser().absolute()
+    try:
+        result = subprocess.run(
+            ["git", "-C", str(abs_watched), "rev-parse", "--git-common-dir"],
+            capture_output=True,
+            text=True,
+            timeout=5,
+        )
+        if result.returncode == 0:
+            git_dir = result.stdout.strip()
+            if not Path(git_dir).is_absolute():
+                git_dir = str(abs_watched / git_dir)
+            abs_path = Path(git_dir).resolve()
+        else:
+            abs_path = abs_watched.resolve()
+    except Exception:
+        abs_path = abs_watched.resolve()
+    return Path.home() / ".cache" / "coderag" / "stores" / _fs_escape(str(abs_path))
+
+
