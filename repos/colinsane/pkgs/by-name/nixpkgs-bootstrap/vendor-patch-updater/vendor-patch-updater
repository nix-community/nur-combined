#!/usr/bin/env -S NIX_BUILD_SHELL=/bin/sh nix-shell
#!nix-shell -i bash ../../../../integrations/nix-shell --arg f 'ps: [ ps.bash ps.curl ps.gitMinimal ps.nix ps.patchutils ]'

set -eu

usage() {
  echo "USAGE: vendor-patch-updater [--revert] [revert-]PR_NUMBER_OR_COMMIT"
  echo "creates or updates the patch file indicated by the PR/commit"
  echo ""
  echo "FLAGS"
  echo "  -o PATH     place the patch at PATH; '-o -' to dump to stdout"
  echo "  --revert    fetch the patch, and then revert it before vendoring."
  echo "              if the patch identifier starts with 'revert-', this is implied"
  echo "              and if --revert is specified then 'revert-' is implicitly prepended to the vendored patch name"
}

# ident: PR number or commit hash
ident=
output=
# revert: "" or "revert-" to signify that `ident` should be reverted before saving to the patches/ dir
revert=
parseArgs() {
  while [ "$#" -ne 0 ]; do
    local arg=$1
    shift
    case $arg in
      (--help)
        usage
        exit 0
        ;;
      (-o)
        output="${1:?-o must be followed by a PATH}"
        shift
        ;;
      (--revert)
        revert=revert-
        ;;
      (*)
        if [ -z "$ident" ]; then
          ident=$arg
        else
          usage
          exit 1
        fi
        ;;
    esac
  done

  if [[ "$ident" == revert-* ]]; then
    revert=revert-
    ident=${ident/revert-/}
  fi

  ident=$(parseIdent $ident)

  if [ -z "$ident" ]; then
    usage
    exit 1
  fi
}

parseIdent() {
  local ident=$1
  # best effort to map various URIs back to their PR or commit number.
  # this function serves the manual invocations to vendor-patch-updater, as updateScripts always pass in the parsed ident.
  ident=${ident/https:\/\/github.com\/NixOS\/nixpkgs\/pull\//}
  ident=${ident/.patch/}
  ident=${ident/.diff/}
  echo "$ident"
}

tryPatchesDir() {
  echo "tryPatchesDir: have='${PATCHES_DIR:-}' .. considering='$1'"
  if [ -z "${PATCHES_DIR:-}" ] && [ -d "$1" ]; then
    export PATCHES_DIR=$1
  fi
}

getPatchesDir() {
  # invoked from update script
  if [ -n "${UPDATE_NIX_ATTR_PATH:-}" ]; then
    local attrPos=$(nix-instantiate --raw --eval -A "$UPDATE_NIX_ATTR_PATH.meta.position")
    if [ -n "$attrPos" ]; then
      tryPatchesDir "$(dirname $(dirname $attrPos))/patches"
    fi
  fi
  # invoked from update script, but the attr path fails to eval (it's a quoting issue, for patches which aren't valid identifiers).
  # or invoked from root
  local gitTop=$(git rev-parse --show-toplevel || true)
  if [ -n "$gitTop" ]; then
    tryPatchesDir "$gitTop/pkgs/by-name/nixpkgs-bootstrap/patches"
  fi
  # fail if unable to locate
  test -n "${PATCHES_DIR:-}"
}

tryUri() {
  local output=$1
  local uri=$2
  local scratch=$(mktemp)
  curl --follow --fail "$uri" -o "$scratch" && test -s "$scratch" && mv "$scratch" "$output"
}

tryGitPatch() {
  local output=$1
  local repo_url=$2
  local commit=$3
  local tmpdir=$(mktemp -d)
  (
    set +e
    cd "$tmpdir"
    git init --quiet
    git remote add origin "$repo_url"
    if git fetch --depth=2 origin "$commit" >/dev/null 2>&1; then
      git -c core.abbrev=12 format-patch -1 --stdout --no-signature --unified=3 "$commit" > "$output"
      test -s "$output"
    else
      false
    fi
  )
  local rc=$?
  rm -rf "$tmpdir"
  return $rc
}

main() {
  local ident=$1
  local scratch=$(mktemp)
  local output_
  case "$output" in
    ("")
      output_=$PATCHES_DIR/$revert$ident.patch
      ;;
    (-)
      output_=/dev/stdout
      ;;
    (*)
      output_=$output
      ;;
  esac
  # N.B.: github's commit endpoint replies to short hashes; a PR number may also be a value short hash,
  # so try the GH commit endpoint *last*. Gitea does not have this problem.
  tryGitPatch "$scratch" "git@git.uninsane.org:colin/nixpkgs.git" "$ident" || \
    tryUri "$scratch" "https://github.com/NixOS/nixpkgs/pull/$ident.patch?full_index=1" || \
    tryUri "$scratch" "https://github.com/uninsane/nixpkgs/commit/$ident.patch?full_index=1"

  if [ -n "$revert" ]; then
    interdiff "$scratch" /dev/null > "$output_"
  else
    cat "$scratch" > "$output_" && rm "$scratch"
  fi
}

parseArgs "$@"
set -x
getPatchesDir
main "$ident"
