-          cabextract
-          cpio
-          gnutar
-          gzip
-          lhasa
-          lzip
-          p7zip
-          rpm
-          unshield
-          xz
-        ]
-        ++ lib.optional unrarSupport unrar
-        ++ lib.optional unzipSupport unzip
-      );
