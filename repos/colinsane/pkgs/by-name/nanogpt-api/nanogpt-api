logger = logging.getLogger(__name__)

class ModelArchitecture(BaseModel):
  input_modalities: list[str]  # audio/image/text/video
  # modality: str  # e.g. "text->text"
  # output_modalities: list[str]  # audio/image/text/video

class ModelCapabilities(BaseModel):
  reasoning: bool
  # audio_input: bool
  # parallel_tool_calls: bool
  # pdf_upload: bool
  # structured_output: bool
  # tool_calling: bool
  # video_input: bool
  # vision: bool

class ModelPricing(BaseModel):
  cacheReadInputPer1kTokens: Optional[float] = None
  completion: Optional[float] = None
  currency: str  # e.g. `USD`
  prompt: Optional[float] = None
  unit: str  # e.g. `per_million_tokens`

class Model(BaseModel):
  id: str
  name: str
  pricing: Optional[ModelPricing] = None
  context_length: Optional[int] = None
  max_output_tokens: Optional[int] = None
  capabilities: Optional[ModelCapabilities] = None
  architecture: Optional[ModelArchitecture] = None
  # api
  # compat
  # cost_estimate
  # created
  # description
  # icon_url
  # owned_by
  # providers
  # subscription
  # thinkingLevelMap

