+bool UinputDevice::EnableProperty(int prop) const {
+  // Tell the kernel that this device has a specific input property (eg: INPUT_PROP_POINTER).
+  int error = syscall_handler_->ioctl(uinput_fd_, UI_SET_PROPBIT, prop);
+  if (error) {
+    LOG(ERROR) << "Unable to enable property 0x" << std::hex << prop <<
+                  " (" << std::dec << error << ")\n";
+    return false;
+  }
+  LOG(DEBUG) << "Enabled property 0x" << std::hex << prop << "\n";
+  return true;
+}
