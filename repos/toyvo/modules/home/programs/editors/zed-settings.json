  "languages": {
    "JSON": {
      "tab_size": 4,
      "formatter": {
        "external": {
          "arguments": [
            "--stdin-filepath",
            "{buffer_path}"
          ],
          "command": "prettier"
        }
      }
    },
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.organizeImports": true
      },
      "formatter": {
        "external": {
          "arguments": [
            "--stdin-filepath",
            "{buffer_path}"
          ],
          "command": "prettier"
        }
      }
    },
    "Nix": {
      "language_servers": [
        "nil",
        "!nixd"
      ]
    },
    "http": {
      "inlay_hints": {
        "enabled": true
      }
    }
  },
  "lsp": {
    "nil": {
      "initialization_options": {
        "formatting": {
          "command": [
            "nixfmt"
          ]
        },
        "nix": {
          "flake": {
            "autoArchive": true
          }
        }
      }
    }
  },
  "terminal": {
    "shell": {
      "program": "fish"
    }
  },
  "theme": {
    "dark": "Catppuccin Frappé (red)",
    "light": "Catppuccin Frappé (red)"
  },
  "ui_font_size": 16,
  "vim_mode": true,
  "auto_install_extensions": {
    "catppuccin-icons": true
  }
}
