new file mode 100644
index 0000000..f98d6c9
--- /dev/null
+++ b/hyuga/walk.hy
@@ -0,0 +1,20 @@
+;; Vendored from hyrule 0.7's `hyrule.collections`. `walk` (with `prewalk` /
+;; `postwalk`) was removed in hyrule 1.0 in favour of `map-model` / `map-hyseq`,
+;; which recurse with a different (None-means-recurse) protocol. hyuga's
+;; traversal relies on walk's single-level inner/outer semantics, so keep the
+;; original here rather than re-architect the walkers.
+
+(import hyrule.iterables [coll?])
+
+(defn walk [inner outer form]
+  "Traverse ``form``, applying ``inner`` to each element and ``outer`` to the
+  result, preserving the structure type."
+  (cond
+    (isinstance form hy.models.Expression)
+      (outer (hy.models.Expression (map inner form)))
+    (or (isinstance form #(hy.models.Sequence list)))
+      ((type form) (outer (hy.models.Expression (map inner form))))
+    (coll? form)
+      (walk inner outer (list form))
+    True
+      (outer form)))
