--- a/wg-quick/linux.bash
+++ b/wg-quick/linux.bash
@@ -82,8 +82,30 @@
 	esac
 }
 
+has_cap_net_admin() {
+	local line
+	# CapEff uses a blank after the colon; CAP_NET_ADMIN is bit 12.
+	while read -r line; do
+		[[ $line =~ ^CapEff:[[:blank:]]+[0-9a-f]*([0-9a-f])[0-9a-f]{3}$ ]] || continue
+		(( 0x${BASH_REMATCH[1]} & 1 != 0 )) && return 0
+		return 1
+	done < /proc/self/status
+	return 1
+}
+
+config_file_is_writable() {
+	# ARGS is (subcommand, CONFIG); interface name expands under /etc/wireguard.
+	local cf="$1" config_file="$cf"
+	[[ $cf =~ ^[a-zA-Z0-9_=+.-]{1,15}$ ]] && config_file="/etc/wireguard/$cf.conf"
+	[[ -w $config_file ]] && return 0
+	return 1
+}
+
 auto_su() {
-	[[ $UID == 0 ]] || exec sudo -p "$PROGRAM must be run as root. Please enter the password for %u to continue: " -- "$BASH" -- "$SELF" "${ARGS[@]}"
+	[[ $UID == 0 ]] && return 0
+	# down only needs caps; up/save need a writable config (ARGS[1]).
+	if has_cap_net_admin; then
+		[[ "${ARGS[0]}" == "down" ]] && return 0
+		config_file_is_writable "${ARGS[1]}" && return 0
+	fi
+	exec sudo -p "$PROGRAM must be run as root. Please enter the password for %u to continue: " -- "$BASH" -- "$SELF" "${ARGS[@]}"
 }
 
