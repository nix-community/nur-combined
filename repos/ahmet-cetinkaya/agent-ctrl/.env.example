# agent-ctrl env template — copy to .env and fill in.
# agent-ctrl substitutes ${VAR} in mcps/*.json and profiles/*/mcps/*.json at apply-time.
# Blank = skip that server/integration. Never commit .env.

# Catalog registries
SKILLSMP_API_KEY=
SMITHERY_API_KEY=

# OmniRoute
OMNIROUTE_BASE_URL=
OMNIROUTE_AUTH_TOKEN=

# Core tooling
MORPH_KEY=
GODOT_PATH=

# Profile: web (firecrawl optional — scrape/crawl works keyless at a rate-limited tier)
FIRECRAWL_API_KEY=

# Developer services
GITHUB_PAT=
CS_ACCESS_TOKEN=
OPENAI_API_KEY=

# Profile: atlassian (jira + confluence share one Atlassian API token)
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
CONFLUENCE_BASE_URL=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=

# Profile: fal-ai
FAL_KEY=

# Profile: supabase (project ref, not a secret)
SUPABASE_PROJECT_REF=

