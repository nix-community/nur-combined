    "esafirm.kotlin-formatter",
    "esbenp.prettier-vscode",
    "esskar.vscode-flutter-i18n-json",
    "everettjf.pubspec-dependency-search",
    "fernandoescolar.vscode-solution-explorer",
    "foxundermoon.shell-format",
    "fwcd.kotlin",
    "google.gemini-cli-vscode-ide-companion",
    "heybourn.headwind",
    "hirantha.json-to-dart",
    "IBM.output-colorizer",
    "JannisX11.batch-rename-extension",
    "jebbs.plantuml",
    "jeroen-meijer.pubspec-assist",
    "jesschadwick.nuget-reverse-package-search",
    "jnoortheen.nix-ide",
    "jock.svg",
    "kamikillerto.vscode-colorize",
    "kilocode.kilo-code",
    "kisstkondoros.vscode-gutter-preview",
    "lokalise.i18n-ally",
    "luanpotter.dart-import",
    "marcelovelasquez.flutter-tree",
    "mikestead.dotenv",
    "mkhl.shfmt",
    "mrmlnc.vscode-attrs-sorter",
    "mrmlnc.vscode-scss",
    "ms-azuretools.vscode-containers",
    "ms-dotnettools.csharp",
    "ms-dotnettools.vscode-dotnet-runtime",
    "ms-vscode.mono-debug",
    "ms-vscode.test-adapter-converter",
    "nhoizey.gremlins",
    "nikiforovall.sync-namespaces-dotnet",
    "nromanov.dotrush",
    "oderwat.indent-rainbow",
    "patcx.vscode-nuget-gallery",
    "PKief.material-icon-theme",
    "redhat.java",
    "redhat.vscode-xml",
    "redhat.vscode-yaml",
    "RedMser.godot-hover-docs",
    "richardwillis.vscode-entity-framework",
    "rinckodev.default-dark-plus",
    "rust-lang.rust-analyzer",
    "SantaCodes.santacodes-region-viewer",
    "stivo.tailwind-fold",
    "streetsidesoftware.code-spell-checker-cspell-bundled-dictionaries",
    "streetsidesoftware.code-spell-checker-turkish",
    "streetsidesoftware.code-spell-checker",
    "tamasfe.even-better-toml",
    "theqtcompany.qt-core",
    "theqtcompany.qt-qml",
    "toroxx.vscode-avdmanager",
    "ultram4rine.vscode-choosealicense",
    "unifiedjs.vscode-mdx",
    "usernamehw.errorlens",
    "vinicioslc.adb-interface-vscode",
    "VisualStudioExptTeam.intellicode-api-usage-examples",
    "VisualStudioExptTeam.vscodeintellicode",
    "vscjava.vscode-gradle",
    "vscjava.vscode-java-debug",
    "vscjava.vscode-java-dependency",
    "vscjava.vscode-java-pack",
    "vscjava.vscode-java-test",
    "vscjava.vscode-maven",
    "wassim-k.rename-replace-extension",
    "wmaurer.change-case",
    "YoavBls.pretty-ts-errors",
    "yoshinorin.image-metadata-viewer",
    "yzhang.markdown-all-in-one",
    "ZhangYue.rust-mod-generator",
  ],
  "files.eol": "\n",
  "files.exclude": {
    "**/bin": true,
    "**/obj": true,
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.hg/store/**": true,
    "**/fdroid/**/**": true,
    "**/node_modules/*/**": true,
  },
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.ignoredRepositories": [],
  "git.openRepositoryInParentFolders": "always",
  "gitlens.telemetry.enabled": false,
  "indentRainbow.indicatorStyle": "light",
  "inlineChat.enableV2": true,
  "kilo-code.new.autocomplete.enableAutoTrigger": true,
  "kilo-code.new.autocomplete.enableChatAutocomplete": false,
  "kilo-code.new.autocomplete.enableSmartInlineTaskKeybinding": false,
  "kilo-code.new.browserAutomation.enabled": true,
  "kilo-code.new.language": "en",
  "kotlin.languageServer.enabled": false,
  "NugetGallery.credentialProviderFolder": "{user-profile}/.nuget/plugins/netcore/CredentialProvider.Microsoft",
  "NugetGallery.skipRestore": false,
  "NugetGallery.sources": ["{\"name\":\"nuget.org\",\"url\":\"https://api.nuget.org/v3/index.json\"}"],
  "prettier.printWidth": 120,
  "redhat.telemetry.enabled": false,
  "svg.preview.autoShow": true,
  "tailwind-fold.autoFold": false,
  "tailwind-fold.unfoldedTextOpacity": 0.6,
  "tailwindCSS.classAttributes": ["class", "className", "ngClass", "styleClass"],
  "tailwindCSS.emmetCompletions": true,
  "tailwindCSS.experimental.classRegex": [
    "tw`([^`]+)`",
    "class$",
    "className$",
    "ngClass$",
    "styleClass$",
    "\\w+Class\\s*=\\s*['\"][^'\"]*['\"]",
    "classnames\\(([^)]*)\\)",
    "[\"'`]([^\"'`]*)[\"'`]",
    "clsx\\(.*?\\)(?!\\])(?:'|\"|`)([^\"'`]*)(?:'|\"|`)",
    "(?:enter|leave)(?:From|To)?=\\s*(?:\"|'|{`)([^(?:\"|'|`})]*)",
    "classnames\\(([^)]*)\\)[\"'`]([^\"'`]*)[\"'`]",
    ":\\s*?[\"'`]([^\"'`]*).*?,",
    "(?:const|let|var)\\s+[\\w$_][_\\w\\d]*\\s*=\\s*['\\\"](.*?)['\\\"]",
    "(?:\\b(?:const|let|var)\\s+)?[\\w$_]*(?:[Ss]tyles|[Cc]lasses|[Cc]lassnames)[\\w\\d]*\\s*(?:=|\\+=)\\s*['\"]([^'\"]*)['\"]",
    "Styles\\s*(?::\\s*[^=]+)?\\s*=\\s*([^;]*);['\"`]([^'\"`]*)['\"`]",
    "tailwind\\('([^)]*)\\')(?:'|\"|`)([^\"'`]*)(?:'|\"|`)",
    "cva\\(([^)]*)\\)[\"'`]([^\"'`]*)[\"'`]",
    "classList={{([^;]*)}}\\s*?[\"'`]([^\"'`]*).*?:",
    "twJoin\\(([^)]*)\\)[\"'`]([^\"'`]*)[\"'`]",
    "(?:twMerge|twJoin)\\(([^;]*)[\\);][`'\"`]([^'\"`;]*)[`'\"`]",
    "tv\\(([^)]*)\\){?\\s?[\\w].*:\\s*?[\"'`]([^\"'`]*).*?,?\\s?}?",
    "(?:add|remove)Class\\(([^)]*)\\)(?:'|\"|`)([^\"'`]*)(?:'|\"|`)",
    "classList.(?:add|remove)\\(([^)]*)\\)(?:'|\"|`)([^\"'`]*)(?:'|\"|`)",
    "@tw\\s\\*\\/\\s+[\"'`]([^\"'`]*)",
    "data-.*-class=['\"]([^'\"]*)",
  ],
  "tailwindCSS.includeLanguages": {
    "ts": "ts",
  },
  "terminal.integrated.commandsToSkipShell": [
    "kilo-code.new.agentManagerOpen",
    "kilo-code.new.agentManager.showTerminal",
  ],
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.fontFamily": "'FiraCode Nerd Font Mono', 'JetBrains Mono Nerd Font Mono', 'Cascadia Code Nerd Font Mono', 'Victor Mono Nerd Font Mono', 'Noto Sans Mono CJK JP', 'Noto Sans Mono CJK SC', 'Noto Sans Mono CJK KR', 'Noto Naskh Arabic', 'Noto Sans Thai', 'Noto Sans Devanagari', 'Noto Color Emoji', 'Noto Sans Symbols 2', 'Noto Sans Symbols', 'DejaVu Sans Mono', monospace",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.initialHint": false,
  "terminal.integrated.stickyScroll.enabled": false,
