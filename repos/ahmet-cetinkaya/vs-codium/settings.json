{
  "[astro]": {
    "editor.defaultFormatter": "astro-build.astro-vscode",
  },
  "[csharp]": {
    "editor.defaultFormatter": "csharpier.csharpier-vscode",
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[dart]": {
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.rulers": [80],
    "editor.selectionHighlight": false,
    "editor.suggestSelection": "first",
    "editor.tabCompletion": "onlySnippets",
    "editor.wordBasedSuggestions": "off",
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[less]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.wordWrap": "on",
    "files.autoSave": "afterDelay",
    "diffEditor.ignoreTrimWhitespace": false,
  },
  "[nix]": {
    "editor.defaultFormatter": "kamadorueda.alejandra",
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[svg]": {
    "editor.defaultFormatter": "jock.svg",
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[xml]": {
    "editor.defaultFormatter": "csharpier.csharpier-vscode",
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "better-comments.multilineComments": true,
  "better-comments.tags": [
    {
      "bold": true,
      "color": "#FFB86C",
      "strikethrough": false,
      "tag": "TODO",
    },
    {
      "color": "#13522f",
      "tag": "//",
    },
    {
      "color": "#2A79AE",
      "tag": "#",
    },
  ],
  "csharpier.enableDiagnostics": false,
  "cSpell.diagnosticLevel": "Hint",
  "cSpell.enableDictionaries": ["en", "tr"],
  "cSpell.ignorePaths": [
    ".git/{index,*refs,*HEAD}",
    ".git/{info,lfs,logs,refs,objects}/**",
    ".gitignore",
    ".vscode-insiders",
    ".vscode",
    "**/settings.json",
    "node_modules",
    "package-lock.json",
    "vscode-extension",
  ],
  "cSpell.language": "en,tr",
  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.renderSideBySide": false,
  "editor.codeActionsOnSave": {
    "source.fixAll": "always",
    "source.removeUnusedImports": "explicit",
  },
  "editor.cursorBlinking": "off",
  "editor.fontFamily": "'FiraCode Nerd Font Mono', 'JetBrains Mono Nerd Font', 'Cascadia Code Nerd Font', 'Victor Mono Nerd Font', 'Noto Sans Mono CJK JP', 'Noto Sans Mono CJK SC', 'Noto Sans Mono CJK KR', 'Noto Naskh Arabic', 'Noto Sans Thai', 'Noto Sans Devanagari', 'Noto Color Emoji', 'Noto Sans Symbols 2', 'Noto Sans Symbols', 'DejaVu Sans Mono', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 16,
  "editor.formatOnSaveMode": "modificationsIfAvailable",
  "editor.lineNumbers": "relative",
  "errorLens.enabledDiagnosticLevels": ["error", "warning"],
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "*": "${capture}.import, ${capture}.uid",
    "*.js": "$(capture).js.map, $(capture).test.js, $(capture).spec.js",
    "*.rs": "$(capture).tests.rs, $(capture).test.rs, $(capture).spec.rs",
    "*.ts": "$(capture).js, $(capture).d.ts.map, $(capture).helper.ts, $(capture).test.ts, $(capture).spec.ts",
    "*.tsx": "$(capture).css, $(capture).scss, $(capture).test.tsx, $(capture).stories.tsx, $(capture).module.css",
    ".env": ".env.*, .env.local, .env.development, .env.production, .env.example",
    ".eslintrc*": ".eslintignore, .eslintrc-model.json",
    ".gitignore": ".gitattributes, .gitmodules, .git-blame-ignore-revs",
    ".prettierrc": ".prettierignore, prettier.config.js",
    "Cargo.toml": "Cargo.lock, cross.toml, .cargo-ok",
    "Dockerfile": ".dockerignore, docker-compose.yml, docker-compose.*.yml",
    "next.config.*": "next-env.d.ts, next.config.mjs",
    "package.json": "package-lock.json, bun.lock, bun.lockb, yarn.lock, pnpm-lock.yaml, .npmrc, .yarnrc",
    "README.md": "LICENSE, CONTRIBUTING.md, CHANGELOG.md, SECURITY.md",
    "tailwind.config.*": "tailwind.config.js, postcss.config.js",
    "tsconfig.json": "tsconfig.*.json",
    "vite.config.*": "vitest.config.*, playwright.config.*",
  },
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1,
  },
  // Nix-packaged builds patchelf the vsce-sign binary (a Node.js SEA), which
  // corrupts its embedded blob and makes every install/update fail with
  // "SignatureVerificationInternal: ... UnknownError". Safe to disable since
  // extensions still come over HTTPS from the marketplace/Open VSX — this
  // only skips the extra signature layer.
  "extensions.verifySignature": false,
  "extensionSync": [
    "aaron-bond.better-comments",
