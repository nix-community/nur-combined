{
  "edit_predictions": {
    "provider": "codestral"
  },
  "diff_view_style": "unified",
  "language_models": {
    "opencode": {
      "show_zen_models": false,
      "show_go_models": false
    }
  },
  "agent": {
    "default_model": {
      "provider": "openrouter",
      "model": "openrouter/free",
      "enable_thinking": true
    },
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "autosave": "off",
  "base_keymap": "VSCode",
  "buffer_font_fallbacks": [
    "CaskaydiaCove Nerd Font Mono",
    "Noto Sans Mono CJK JP",
    "Noto Sans Mono CJK SC",
    "Noto Sans Mono CJK KR",
    "Noto Sans Symbols",
  ],
  "buffer_font_family": "FiraCode Nerd Font Mono",
  "buffer_font_size": 16,
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "colorize_brackets": true,
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {},
    },
  },
  "cursor_blink": false,
  "git": {
    "git_gutter": "tracked_files",
  },
  "git_panel": {
    "group_by": "status",
    "dock": "left",
    "sort_by_path": true,
    "tree_view": true,
  },
  "icon_theme": "Material Icon Theme",
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "inlayHints": {
          "closureReturnTypeHints": {
            "enable": "always",
          },
          "lifetimeElisionHints": {
            "enable": "skip_trivial",
            "useParameterNames": true,
          },
          "maxLength": null,
        },
        "rust": {
          "analyzerTargetDir": true,
        },
      },
    },
  },
  "outline_panel": {
    "dock": "left",
  },
  "project_panel": {
    "dock": "left",
  },
  "relative_line_numbers": "enabled",
  "scroll_beyond_last_line": "off",
  "scrollbar": {
    "show": "never",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "button": false,
    "dock": "right",
    "font_fallbacks": [
      "CaskaydiaCove Nerd Font Mono",
      "Noto Sans Mono CJK JP",
      "Noto Sans Mono CJK SC",
      "Noto Sans Mono CJK KR",
      "Noto Sans Symbols",
    ],
    "font_family": "FiraCode Nerd Font Mono",
    "font_size": 14,
    "line_height": "standard",
    "shell": "system",
    "working_directory": "current_project_directory",
  },
  "theme": "VSCode Dark Modern",
  "ui_font_size": 16,
  "vertical_scroll_margin": 0,
  "vim_mode": true,
}
